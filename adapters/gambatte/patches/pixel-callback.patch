diff --git a/libgambatte/src/video/ppu.h b/libgambatte/src/video/ppu.h
--- a/libgambatte/src/video/ppu.h
+++ b/libgambatte/src/video/ppu.h
@@ -38,17 +38,57 @@ enum { lcd_hres = 160, lcd_vres = 144, lcd_lines_per_frame = 154 };
 enum { max_num_palettes = 8, num_palette_entries = 4 };
 enum { lcd_max_num_sprites_per_line = 10 };

+// Callback type for per-pixel output notification.
+// Arguments: user_data, x, y, shade (0-3)
+typedef void (*pixel_callback_t)(void *user_data, int x, int y, int shade);
+
+// Proxy buffer that intercepts pixel writes and forwards to a callback.
+// Wraps a real destination buffer line.
+class PixelProxyLine {
+public:
+	PixelProxyLine() : dst_(0), ly_(0), offset_(0), cb_(0), cb_data_(0), palette_(0) {}
+
+	void setup(uint_least32_t *dst, unsigned ly, int offset,
+	           pixel_callback_t cb, void *cb_data,
+	           unsigned long const *palette) {
+		dst_ = dst; ly_ = ly; offset_ = offset;
+		cb_ = cb; cb_data_ = cb_data; palette_ = palette;
+	}
+
+	uint_least32_t *raw() { return dst_; }
+
+	void write(int x, uint_least32_t rgba) {
+		if (dst_) dst_[x] = rgba;
+		if (cb_ && palette_) {
+			int lcd_x = x + offset_;
+			if (lcd_x >= 0 && lcd_x < 160 && ly_ < 144) {
+				// Reverse-lookup shade from palette value
+				int shade = 0;
+				for (int i = 0; i < 4; i++) {
+					if (palette_[i] == rgba) { shade = i; break; }
+				}
+				cb_(cb_data_, lcd_x, ly_, shade);
+			}
+		}
+	}
+
+private:
+	uint_least32_t *dst_;
+	unsigned ly_;
+	int offset_;
+	pixel_callback_t cb_;
+	void *cb_data_;
+	unsigned long const *palette_;
+};
+
 class PPUFrameBuf {
 public:
-	PPUFrameBuf() : buf_(0), fbline_(nullfbline()), pitch_(0) {}
+	PPUFrameBuf() : buf_(0), fbline_(nullfbline()), pitch_(0),
+	                pixel_cb_(0), pixel_cb_data_(0) {}
 	uint_least32_t * fb() const { return buf_; }
 	uint_least32_t * fbline() const { return fbline_; }
 	std::ptrdiff_t pitch() const { return pitch_; }
 	void setBuf(uint_least32_t *buf, std::ptrdiff_t pitch) { buf_ = buf; pitch_ = pitch; fbline_ = nullfbline(); }
 	void setFbline(unsigned ly) { fbline_ = buf_ ? buf_ + std::ptrdiff_t(ly) * pitch_ : nullfbline(); }
+	void setPixelCallback(pixel_callback_t cb, void *data) { pixel_cb_ = cb; pixel_cb_data_ = data; }
+	pixel_callback_t pixelCallback() const { return pixel_cb_; }
+	void *pixelCallbackData() const { return pixel_cb_data_; }

 private:
 	uint_least32_t *buf_;
 	uint_least32_t *fbline_;
 	std::ptrdiff_t pitch_;
+	pixel_callback_t pixel_cb_;
+	void *pixel_cb_data_;

 	static uint_least32_t * nullfbline() { static uint_least32_t nullfbline_[160]; return nullfbline_; }
 };
