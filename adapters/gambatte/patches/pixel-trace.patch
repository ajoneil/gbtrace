--- /dev/null
+++ b/libgambatte/include/pixelbuf.h
@@ -0,0 +1,40 @@
+#ifndef PIXELBUF_H
+#define PIXELBUF_H
+
+// Simple ring buffer for per-pixel shade output.
+// Capacity is generous: one full frame = 160*144 = 23040 pixels.
+// At instruction level, the buffer is drained every ~4 T-cycles.
+
+class PixelBuf {
+public:
+	static const int CAPACITY = 160 * 144 + 256; // one frame + slack
+
+	PixelBuf() : head_(0), tail_(0) {}
+
+	void push(unsigned char shade) {
+		buf_[head_ % CAPACITY] = shade;
+		++head_;
+	}
+
+	int size() const { return head_ - tail_; }
+
+	unsigned char const * data() const { return buf_ + (tail_ % CAPACITY); }
+
+	// Read up to `n` pixels into dst, return count actually read.
+	int read(char *dst, int n) const {
+		int avail = size();
+		if (n > avail) n = avail;
+		for (int i = 0; i < n; i++) {
+			dst[i] = '0' + buf_[(tail_ + i) % CAPACITY];
+		}
+		return n;
+	}
+
+	void clear() { tail_ = head_; }
+	void reset() { head_ = tail_ = 0; }
+
+private:
+	unsigned char buf_[CAPACITY];
+	int head_;
+	int tail_;
+};
+
+#endif
